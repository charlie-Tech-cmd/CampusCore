# ===========================
# CampusCore Server
# ===========================

SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# ===========================
# PostgreSQL
# ===========================

DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=campuscore
DB_SSLMODE=disable

DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=30m
DB_CONN_MAX_IDLE_TIME=5m

# ===========================
# Authentication
# ===========================

JWT_SECRET=change-me-before-production
JWT_EXPIRATION=24h

# ===========================
# Notification Worker
# ===========================

WORKER_POOL_SIZE=5